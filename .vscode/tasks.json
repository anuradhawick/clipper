{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build rust backend",
      "type": "shell",
      "command": "cargo",
      "args": [
        "build",
        "--manifest-path",
        "${workspaceFolder}/src-tauri/Cargo.toml"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src-tauri"
      },
      "problemMatcher": [
        "$rustc"
      ],
      "group": "build"
    }
  ]
}
